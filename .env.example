# ========================
# App Settings
# ========================
APP_SECRET_KEY=your-super-secret-key-change-this-in-production
APP_BASE_URL=http://localhost:8000

# ========================
# MongoDB Atlas
# ========================
MONGODB_URL=mongodb+srv://cristthien:Thien123456789@cluster0.noxatqm.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=sheet_notifier

# ========================
# Google OAuth (Login + Sheets)
# ========================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redirect URIs (register both in Google Cloud Console)
# Login:  http://localhost:8000/auth/callback
# Sheets: http://localhost:8000/google/callback

# ========================
# Worker Config
# ========================
# Secret để bảo vệ POST /worker/run endpoint (Cron Job dùng header này)
WORKER_SECRET=your-worker-secret-key

# Default poll interval (seconds) - user có thể override per watch
DEFAULT_POLL_INTERVAL=30
